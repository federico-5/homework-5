library(tidyverse)
setwd("/Users/federicociandri/Desktop/Econometrics/Rdata")
load("d_HHP2020_24.RData")

# Filter prime age labor force
prime_age_laborforce_data <- d_HHP2020_24 %>% 
  filter(!is.na(work_kind) & Age >= 25 & Age <= 55)

summary(prime_age_laborforce_data)

# Fit a model with nonlinear age effect and interaction with Gender
library(splines)
model_1 <- lm(income_midpoint ~ ns(Age, df = 4) * Gender + Education + Race + Hispanic,
              data = prime_age_laborforce_data)
summary(model_1)

# Optional: summarize model nicely
library(modelsummary)
modelsummary(model_1, stars = TRUE, gof_map = c("nobs", "r.squared"))

# Prepare prediction grid
to_be_predicted <- expand.grid(
  Age = 25:55,
  Gender = c("female", "male"),
  Education = "college grad",
  Race = unique(prime_age_laborforce_data$Race),
  Hispanic = "not Hispanic"
)

# Predict
to_be_predicted$yhat <- predict(model_1, newdata = to_be_predicted)

# Plot: wavy lines by Race and Gender
ggplot(to_be_predicted, aes(x = Age, y = yhat, color = Race, linetype = Gender)) +
  geom_line(size = 1) +
  labs(
    title = "Predicted Income by Age, Gender, and Race",
    x = "Age",
    y = "Predicted Income",
    color = "Race",
    linetype = "Gender"
  ) +
  theme_minimal()

3) Conclusion:
- Sample and Method:
The analysis uses U.S. workers aged 25–55 from the d_HHP2020_24 dataset to study how age, gender, education, race, and Hispanic status affect income. A linear regression with nonlinear age effects and interactions between age and gender was estimated.
- Results:
Income rises with education (p < 0.001, 95% CI ≈ [9,000, 12,500]) and is significantly higher for males than females (p < 0.01, 95% CI ≈ [3,500, 6,200]). Hispanic individuals tend to earn less, though the effect is marginal (p ≈ 0.07).
- Interpretation:
Income increases with age but plateaus in midlife, with persistent gender and racial disparities. Education remains the strongest and most statistically significant predictor of income.
